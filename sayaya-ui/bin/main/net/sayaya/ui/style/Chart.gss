.odd-row {
	background-color: #FFFFFF !important;
}

.even-row {
	background-color: rgb(240, 240, 240) !important;
}

.error-row {
	background-color: #9A3033 !important;
}

.selected-row {
	background-color: rgba(44, 39, 43, 0.18) !important;
}

.empty {
	width: 100%;
	height: 100%;
	text-align: center;
}