.flat {
	text-rendering: optimizeLegibility;
	-webkit-font-smoothing: antialiased;
	font-family: 'Noto Sans KR', sans-serif;
	font-weight: bold;
	text-transform: uppercase;
	min-width: 8em;
	background-color: transparent;
	color: eval("net.sayaya.ui.style.color.Palette.getInstance().getColor1()");
	border: 0px hidden;
	border-radius: 3px;
	cursor: pointer;
	-webkit-user-select: none;
	-khtml-user-select: none;
	-moz-user-select: none;
	-o-user-select: none;
	user-select: none;
	outline-style: none;
	padding: 0.5em;
	letter-spacing: 1px;
}

.flat:hover:enabled {
	animation-duration: 0.4s;
	animation-name: fi;
	animation-fill-mode: forwards;
}

@keyframes fi {
	from {
		background-color: transparent;
	}
	to {
		background-color: eval("net.sayaya.ui.style.color.Palette.toRGBA(net.sayaya.ui.style.color.Palette.getInstance().getColor1(), 0.25)");
	}
}

.flat:disabled {
	color: eval("net.sayaya.ui.style.color.Palette.getInstance().getColorText3()");
}

.rised {
	text-rendering: optimizeLegibility;
	-webkit-font-smoothing: antialiased;
	font-family: 'Noto Sans KR', sans-serif;
	font-weight: bold;
	text-transform: uppercase;
	min-width: 8em;
	background-color: #FFFFFF;
	color: eval("net.sayaya.ui.style.color.Palette.getInstance().getColor1()");
	box-shadow : 0px 3px 3px rgba(0,0,0,0.16), 0px 3px 3px rgba(0,0,0,0.23);
	border: 0px hidden;
	border-radius: 3px;
	cursor: pointer;
	-webkit-user-select: none;
	-khtml-user-select: none;
	-moz-user-select: none;
	-o-user-select: none;
	user-select: none;
	padding: 0.5em;
	letter-spacing: 1px;
}

.rised:hover:enabled {
	animation-duration: 0.4s;
	animation-name: elevation;
	animation-fill-mode: forwards;
}

.rised:disabled {
	color: eval("net.sayaya.ui.style.color.Palette.getInstance().getColorText3()");
	box-shadow : 0 0;
}

@keyframes elevation {
	from {
		box-shadow : 0px 3px 3px rgba(0,0,0,0.16), 0px 3px 3px rgba(0,0,0,0.23);
	}
	to {
		box-shadow : 0px 10px 10px rgba(0,0,0,0.19), 0px 6px 3px rgba(0,0,0,0.23);
	}
}

.contained {
	text-rendering: optimizeLegibility;
	-webkit-font-smoothing: antialiased;
	font-family: 'Noto Sans KR', sans-serif;
	font-weight: bold;
	text-transform: uppercase;
	min-width: 8em;
	background-color: eval("net.sayaya.ui.style.color.Palette.getInstance().getColor1()");
	box-shadow : 0px 3px 3px rgba(0,0,0,0.16), 0px 3px 3px rgba(0,0,0,0.23);
	color: #FFFFFF;
	border: 0px hidden;
	border-radius: 3px;
	cursor: pointer;
	-webkit-user-select: none;
	-khtml-user-select: none;
	-moz-user-select: none;
	-o-user-select: none;
	user-select: none;
	outline-style: none;
	padding: 0.5em;
	letter-spacing: 1px;
}

.contained:hover:enabled {
	animation-duration: 0.4s;
	animation-name: elevation;
	animation-fill-mode: forwards;
}

.contained:disabled {
	color: eval("net.sayaya.ui.style.color.Palette.getInstance().getColorText3()");
}

.toggle {
	text-rendering: optimizeLegibility;
	-webkit-font-smoothing: antialiased;
	min-width: 3em;
	background-color: #FFFFFF;
	color: eval("net.sayaya.ui.style.color.Palette.getInstance().getColorText1()");
	border: 1px solid eval("net.sayaya.ui.style.color.Palette.getInstance().getColorDevider()");
	border-right: 0px;
	cursor: pointer;
	-webkit-user-select: none;
	-khtml-user-select: none;
	-moz-user-select: none;
	-o-user-select: none;
	user-select: none;
	padding: 0.5em;
	letter-spacing: 1px;
}

.toggle:hover:enabled {
	background-color: rgba(0, 0, 0, 0.05);
}

.toggle-true:enabled {
	font-weight: bold;
	background-color: rgba(0, 0, 0, 0.15);
	box-shadow : inset 0 3px 6px rgba(0,0,0,0.19), inset 0 1px 2px rgba(0,0,0,0.23);
}

.toggle-true:hover:enabled {
	background-color: rgba(0, 0, 0, 0.15);
}

.toggle:first-of-type {
	border-top-left-radius: 3px;
	border-bottom-left-radius: 3px;
}

.toggle:last-of-type {
	border-right: 1px solid eval("net.sayaya.ui.style.color.Palette.getInstance().getColorDevider()");
	border-top-right-radius: 3px;
	border-bottom-right-radius: 3px;
}

.toggle:disabled {
	color: eval("net.sayaya.ui.style.color.Palette.getInstance().getColorDevider()");
}