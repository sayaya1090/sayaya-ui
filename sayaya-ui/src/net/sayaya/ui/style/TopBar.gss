.topbar {
	text-rendering: optimizeLegibility;
	-webkit-font-smoothing: antialiased;
	background-color: eval("net.sayaya.ui.style.color.Palette.getInstance().getColor1()");
	position: relative;
	height: 100%;
	display: table;
	-webkit-user-select: none;
	-khtml-user-select: none;
	-moz-user-select: none;
	-o-user-select: none;
	user-select: none;
}